{
  enabled: true,
  extends: [
    'group:recommended',
    'workarounds:all',
  ],
  dependencyDashboard: true,
  branchConcurrentLimit: 0,
  prConcurrentLimit: 0,
  prHourlyLimit: 0,
  rebaseWhen: 'conflicted',
  ignoreUnstable: false,
  respectLatest: false,
  packageRules: [
    {
      matchDatasources: [
        'maven',
      ],
      registryUrls: [
        'https://repo.maven.apache.org/maven2/',
        'https://jitpack.io/',
        'https://oss.sonatype.org/service/local/repo_groups/public/content',
        'https://repo.osgeo.org/repository/release',
        'https://repo.kotlin.link',
        'https://maven.pkg.jetbrains.space/kotlin/p/kotlin/kotlin-js-wrappers',
        'https://s01.oss.sonatype.org/content/repositories/snapshots',
        'https://packages.jetbrains.team/maven/p/kds/kotlin-ds-maven',
      ],
    },
    {
      allowedVersions: '!/[-.]((dev)|(SNAPSHOT)|(snapshot))/',
      matchPackageNames: [
        '/.*/',
      ],
    },
    {
      matchCurrentValue: '/[-.]dev/',
      allowedVersions: '/.*/',
    },
    {
      matchPackageNames: [
        'org.jetbrains.kotlinx:dataframe',
      ],
      allowedVersions: '!/[-.]dev|^1548$|^1727$/',
    },
    {
      matchPackageNames: [
        'org.jetbrains.kotlinx:kotlin-jupyter-intellij-platform',
        'org.jetbrains.kotlinx:kotlin-jupyter-database',
      ],
      allowedVersions: '!/^1$/',
    },
    {
      matchPackageNames: [
        'com.github.gabrielfeo:gradle-enterprise-api-kotlin',
      ],
      allowedVersions: '!/^0\\.999.*$/',
    },
    {
      matchPackageNames: [
        'org.jetbrains.kotlinx:kotlinx-datetime',
      ],
      allowedVersions: '!/^0\\.7\\.1-0\\.6\\.x-compat$/',
    },
    {
      matchPackageNames: [
        'org.slf4j:slf4j-api',
        'org.jetbrains.kotlinx:kotlin-deeplearning-api',
        'com.github.kittinunf.fuel:fuel',
      ],
      allowedVersions: '!/^((alpha)|(beta)|(dev)|(rc))$/',
    },
    {
      matchDatasources: [
        'maven',
      ],
      matchPackageNames: [
        'org.jetbrains.kotlinx:kotlin-jupyter-database',
        'org.jetbrains.kotlinx:kotlin-jupyter-intellij-platform',
        'org.jetbrains.kotlinx:kotlin-jupyter-ktor-client',
        'org.jetbrains.kotlinx:kotlin-jupyter-notekit-jupyter',
        'org.jetbrains.kotlinx:kotlin-jupyter-serialization',
        'org.jetbrains.kotlinx:kotlin-jupyter-widgets-jupyter',
      ],
      automerge: true,
      automergeType: 'pr',
    },
  ],
  customManagers: [
    {
      customType: 'regex',
      datasourceTemplate: 'maven',
      versioningTemplate: 'maven',
      managerFilePatterns: [
        '/.*\\.json5/',
      ],
      matchStrings: [
        '^\\s*"(?<depName>[^":\\$]+:[^":\\$]+):(?<currentValue>[^":\\$]+)"',
      ],
    },
    {
      customType: 'regex',
      datasourceTemplate: 'maven',
      versioningTemplate: 'maven',
      managerFilePatterns: [
        '/.*\\.json/',
      ],
      matchStrings: [
        '(?:{ *"name": *)?".+?"[:,] *(?:"value": *)?"(?<currentValue>.+?)"(?: *})?,\\s*(?:{ *"name": *)?"\\S+-renovate-hint"[:,] *(?:"value": *)?"update: +package=(?<depName>\\S+?)"',
      ],
    },
  ],
}
